server {
    # 匹配 docker-compose 端口
    listen       8000;
    listen  [::]:8000;
    server_name  localhost;

    # 1. 托管前端静态文件
    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;
        # 核心配置：支持 Vue Router 的 History 模式
        # 如果找不到文件（如刷新页面时），回退到 index.html
        try_files $uri $uri/ /index.html;
    }

    # 2. 反向代理 API 请求 (替代 vite.config.ts 中的 proxy)
    # 假设你的后端接口都以 /api 开头
    location /api/ {
        # ${AICOPILOT_HTTPAPI_HTTP} 会在容器启动时被真实地址替换
        # 例如替换为 http://aicopilot-httpapi:8080
        proxy_pass ${AICOPILOT_HTTPAPI_HTTP}/api/;

        # 标准代理头设置
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    # 可选：如果还需要代理 Swagger
    location /swagger/ {
        proxy_pass ${AICOPILOT_HTTPAPI_HTTP}/swagger/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}